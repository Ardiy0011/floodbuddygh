# Base URL of the FloodBuddy API.
# Vite only exposes vars prefixed with VITE_ to the client bundle.
VITE_API_URL=http://localhost:4000

# --- Firebase Web App config (Google sign-in) ---
# From Firebase Console → Project Settings → General → Your apps → Web app →
# "SDK setup and configuration". These are NOT secrets (safe in the bundle).
VITE_FIREBASE_API_KEY=AIzaSy...your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
